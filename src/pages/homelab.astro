---
/**
 * /homelab — Self-hosted infrastructure showcase.
 * Terminal-inspired design with lighter page background,
 * narrative content, and mono-font terminal cards.
 *
 * Phase 1: Self-contained prototype with inline dummy data.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const homelabServices = [
  { "@type": "ListItem" as const, "position": 1, "name": "Cloudflare Tunnel", "description": "Secure reverse tunnel for external access" },
  { "@type": "ListItem" as const, "position": 2, "name": "Docker", "description": "Container runtime with Compose V2" },
  { "@type": "ListItem" as const, "position": 3, "name": "Portainer", "description": "Docker management UI", "url": "https://portainer.princejain.me" },
  { "@type": "ListItem" as const, "position": 4, "name": "Immich", "description": "Self-hosted photo and video library", "url": "https://immich.princejain.me" },
  { "@type": "ListItem" as const, "position": 5, "name": "Vaultwarden", "description": "Self-hosted password manager", "url": "https://vault.princejain.me" },
  { "@type": "ListItem" as const, "position": 6, "name": "AdGuard Home", "description": "Network-wide DNS ad blocker" },
  { "@type": "ListItem" as const, "position": 7, "name": "Stirling PDF", "description": "Self-hosted PDF toolkit", "url": "https://pdf.princejain.me" },
  { "@type": "ListItem" as const, "position": 8, "name": "n8n", "description": "Automation workflows", "url": "https://n8n.princejain.me" },
  { "@type": "ListItem" as const, "position": 9, "name": "OpenClaw", "description": "Personal AI assistant" },
];
---

<BaseLayout
  title="Home Lab | Prince Jain"
  description="Self-hosted infrastructure on a headless MacBook - Immich, Vaultwarden, AdGuard, n8n, and more, secured through Cloudflare Tunnels."
  breadcrumbs={[
    { name: "Home", url: "https://princejain.me" },
    { name: "Home Lab" },
  ]}
  extraSchema={{
    "@type": "ItemList",
    "name": "Home Lab Services",
    "description": "Self-hosted services running on Prince Jain's home lab infrastructure",
    "numberOfItems": homelabServices.length,
    "itemListElement": homelabServices,
  }}
>

<!-- ═══════════════════════════════════════════════════════════
     SECTION 1: Page Header + Terminal Hero
     ═══════════════════════════════════════════════════════════ -->
<section class="lab-hero">
  <div class="container">
    <div class="lab-hero__intro animate-fade-up">
      <h1 class="lab-hero__title">The Home Lab</h1>
      <p class="lab-hero__desc">
        My photos, passwords, and automation workflows were spread across a dozen SaaS tools and cloud providers
        (me trying to maximally utilise different free-tiers :P) - each with its own subscription, limits, and
        general overhead of managing. I replaced all of them with a single self-hosted system running on a
        repurposed MacBook Air.
      </p>
      <p class="lab-hero__subtext">
        Here are the details on how I built a low-cost, production-grade infrastructure that scratches most of
        my experimentation itch these days.
      </p>
    </div>

    <div class="terminal homelab-animate">
      <div class="terminal__bar">
        <span class="terminal__dot terminal__dot--red"></span>
        <span class="terminal__dot terminal__dot--yellow"></span>
        <span class="terminal__dot terminal__dot--green"></span>
        <span class="terminal__bar-title">prince@ubuntu-mac: ~/homelab</span>
      </div>
      <div class="terminal__content">
        <div class="hero-prompt">
          <span class="prompt-user">prince@ubuntu-mac</span><span class="prompt-sep">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span> neofetch --homelab
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat__label">Uptime</span>
            <span class="hero-stat__value">24/7</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat__label">Services</span>
            <span class="hero-stat__value">9 running</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat__label">Nodes</span>
            <span class="hero-stat__value">MacBook Air + GPU helper</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat__label">Open Ports</span>
            <span class="hero-stat__value">0 (Cloudflare Tunnels)</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat__label">Status</span>
            <span class="hero-stat__value hero-stat__value--live">All systems operational <span class="live-dot"></span></span>
          </div>
        </div>
        <div class="hero-prompt hero-prompt--bottom">
          <span class="prompt-user">prince@ubuntu-mac</span><span class="prompt-sep">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span> <span class="cursor"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════
     SECTION 2: Network Topology
     ═══════════════════════════════════════════════════════════ -->
<section class="lab-section">
  <div class="container">
    <div class="section-intro homelab-animate">
      <h2 class="section-heading">How it all connects</h2>
      <p class="section-desc">
        All traffic from the internet hits Cloudflare first - TLS, caching, DDoS protection, the works.
        A lightweight <code>cloudflared</code> daemon on the MacBook maintains an outbound-only tunnel, so nothing
        on my home network is directly reachable from outside. A second laptop with an NVIDIA GPU sits on the
        local network purely for Immich's ML workloads (face detection, smart search).
      </p>
      <p class="section-tradeoff homelab-animate">
        <span class="tradeoff-label">Key tradeoff:</span> I went with Cloudflare Tunnels over port forwarding or a self-managed
        reverse proxy. Since it eliminates the attack surface entirely and easy to manage for a simple home setup.
        Zero open ports, no router config to maintain, and has been worth it.
      </p>
    </div>
    <div class="section-cmd">
      <span class="prompt-dollar">$</span> cat /etc/homelab/topology.txt
    </div>
