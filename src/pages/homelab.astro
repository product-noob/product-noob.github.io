│</span>  <span class="topo-accent">│</span>  ├─ portainer:9000 <span class="topo-live">[●]</span>  <span class="topo-accent">│</span>                                <span class="topo-muted">│
│</span>  <span class="topo-accent">│</span>  ├─ pdf:8080       <span class="topo-live">[●]</span>  <span class="topo-accent">│</span>                                <span class="topo-muted">│
│</span>  <span class="topo-accent">│</span>  ├─ n8n:5678       <span class="topo-live">[●]</span>  <span class="topo-accent">│</span>                                <span class="topo-muted">│
