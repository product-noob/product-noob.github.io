<!-- ═══════════════════════════════════════════════════════════
     Scroll Animation Script
     ═══════════════════════════════════════════════════════════ -->
<script>
  function initHomelabAnimations(): void {
    const items = document.querySelectorAll<HTMLElement>('.homelab-animate');
    if (!items.length) return;

    const MAX_STAGGER_DELAY = 600;
    const STAGGER_STEP = 120;
    let staggerIndex = 0;
    let resetTimer: ReturnType<typeof setTimeout> | null = null;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = Math.min(staggerIndex * STAGGER_STEP, MAX_STAGGER_DELAY);
            staggerIndex++;
            window.setTimeout(() => {
              el.classList.add('is-visible');
            }, delay);
            observer.unobserve(el);
          }
        });
        if (resetTimer) clearTimeout(resetTimer);
        resetTimer = setTimeout(() => { staggerIndex = 0; }, 300);
      },
      { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
    );

    items.forEach((item) => observer.observe(item));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHomelabAnimations);
  } else {
    initHomelabAnimations();
  }
</script>
