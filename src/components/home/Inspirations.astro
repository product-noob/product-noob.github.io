---
/**
 * Inspirations — "People Who Inspire Me" card grid.
 * Self-contained: owns its markup, styles, and client-side script.
 * Dummy data — swap names, descriptions, images, and URLs later.
 */
import type { PersonInspiration } from '../../types';

const people: (PersonInspiration & { initials: string; bgColor: string })[] = [
  {
    name: 'Lenny Rachitsky',
    description: 'Product, growth, and the mastermind behind the #1 product newsletter.',
    url: 'https://www.lennysnewsletter.com/',
    image: '',
    initials: 'LR',
    bgColor: '#6366F1',
  },
  {
    name: 'Shreyas Doshi',
    description: 'Former PM at Stripe, Twitter, Google — prolific thinker on product craft.',
    url: 'https://twitter.com/shreyas',
    image: '',
    initials: 'SD',
    bgColor: '#0EA5E9',
  },
  {
    name: 'Paul Graham',
    description: 'Co-founder of Y Combinator. Essayist on startups, tech, and thinking clearly.',
    url: 'https://paulgraham.com/',
    image: '',
    initials: 'PG',
    bgColor: '#F59E0B',
  },
  {
    name: 'Naval Ravikant',
    description: 'AngelList founder. Philosopher-investor on wealth, leverage, and judgement.',
    url: 'https://nav.al/',
    image: '',
    initials: 'NR',
    bgColor: '#10B981',
  },
  {
    name: 'Ben Thompson',
    description: 'Stratechery founder. The sharpest analyst on tech strategy and aggregation.',
    url: 'https://stratechery.com/',
    image: '',
    initials: 'BT',
    bgColor: '#14B8A6',
  },
  {
    name: 'Shrinivas SG',
    description: 'My former manager and a defining influence on how I think about people leadership.',
    url: 'https://x.com/shrinivassg',
    image: '',
    initials: 'SG',
    bgColor: '#8B5CF6',
  },
];
---

<section class="inspirations">
  <div class="container">
    <div class="inspirations__header">
      <h2 class="inspirations__title">People Who Inspire Me</h2>
      <p class="inspirations__subtitle">Thinkers and builders who shaped how I think about product.</p>
    </div>

    <div class="inspirations__grid">
      {people.map((person, i) => (
        <a
          href={person.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inspire-card"
          style={`--accent: ${person.bgColor}; animation-delay: ${i * 60}ms`}
        >
          <span class="inspire-card__initials">{person.initials}</span>
          <div class="inspire-card__info">
            <p class="inspire-card__name">{person.name}</p>
            <p class="inspire-card__desc">{person.description}</p>
          </div>
          <svg class="inspire-card__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .inspirations {
    padding: var(--space-16) 0 var(--space-24);
    position: relative;
  }

  .inspirations__header {
    margin-bottom: var(--space-8);
  }

  .inspirations__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--gray-900);
    position: relative;
    padding-bottom: var(--space-3);
  }

  .inspirations__title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 48px;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent), transparent);
    border-radius: 2px;
  }

  .inspirations__subtitle {
    font-size: var(--text-sm);
    color: var(--gray-500);
    line-height: 1.6;
    margin: var(--space-2) 0 0 0;
  }

  /* Grid: 2 cols desktop, 1 col mobile */
  .inspirations__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }

  @media (min-width: 1024px) {
    .inspirations__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card — horizontal layout */
  .inspire-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--gray-200);
    background: white;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
  }

  .inspire-card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--accent) 15%, transparent);
    transform: translateY(-2px);
  }

  /* Initials circle */
  .inspire-card__initials {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.03em;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .inspire-card__info {
    flex: 1;
    min-width: 0;
  }

  .inspire-card__name {
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--gray-900);
    line-height: 1.3;
    margin: 0 0 var(--space-1) 0;
  }

  .inspire-card__desc {
    font-size: var(--text-xs);
    color: var(--gray-500);
    line-height: 1.5;
    margin: 0;
  }

  .inspire-card__arrow {
    flex-shrink: 0;
    color: var(--gray-300);
    margin-top: 2px;
    transition: all var(--transition-fast);
  }

  .inspire-card:hover .inspire-card__arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  /* Responsive */
  @media (max-width: 767px) {
    .inspirations {
      padding: var(--space-12) 0 var(--space-16);
    }

    .inspirations__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .inspire-card {
      padding: var(--space-3) var(--space-4);
    }

    .inspire-card__initials {
      width: 36px;
      height: 36px;
    }
  }
</style>
